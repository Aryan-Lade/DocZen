# Server Environment Variables
NODE_ENV=development
PORT=5000

# MySQL (Railway Support)
# If using a single connection URL (recommended for Railway):
DATABASE_URL=mysql://root:password@localhost:3306/docfusion
# Or individual variables:
MYSQLHOST=localhost
MYSQLPORT=3306
MYSQLUSER=root
MYSQLPASSWORD=password
MYSQLDATABASE=docfusion
MYSQL_SSL=false

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=30d

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# LibreOffice path (for office to PDF conversion)
# Windows: C:\Program Files\LibreOffice\program\soffice.exe
# Linux: /usr/bin/libreoffice
LIBREOFFICE_PATH=libreoffice

# Ghostscript path (for advanced PDF compression)
# Windows: C:\Program Files\gs\gs10.03.1\bin\gswin64c.exe
# Linux: /usr/bin/gs
GHOSTSCRIPT_PATH=gs
